---
import path from "node:path";
import type { CollectionEntry } from "astro:content";
import { profileConfig, siteConfig, umamiConfig } from "@/config";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import Markdown from "@components/misc/Markdown.astro";
import MermaidRenderer from "@components/misc/MermaidRenderer.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedWorks } from "@utils/content-utils";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { getDir } from "@utils/url-utils";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
	const works = await getSortedWorks();
	return works.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props as { entry: CollectionEntry<"works"> };
const { Content, headings } = await entry.render();

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CreativeWork",
	name: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
	...(entry.data.image && {
		image: new URL(entry.data.image, Astro.site).href,
	}),
	...(entry.data.video && { video: entry.data.video }),
};
---

<MainGridLayout
	banner={entry.data.image}
	title={entry.data.title}
	description={entry.data.description}
	lang={entry.data.lang}
	setOGTypeArticle={true}
	headings={headings}
>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

	<article class="card-base relative z-10 overflow-hidden rounded-[var(--radius-large)] px-6 pb-6 pt-6 md:px-9">
		<div class="mb-5 flex flex-wrap items-center gap-3 text-sm text-black/45 dark:text-white/45">
			<span class="inline-flex items-center gap-2">
				<Icon name="material-symbols:calendar-today-outline-rounded" class="text-lg text-[var(--primary)]" />
				{formatDateToYYYYMMDD(entry.data.published)}
			</span>
			{entry.data.updated && entry.data.updated.getTime() !== entry.data.published.getTime() && (
				<span class="inline-flex items-center gap-2">
					<Icon name="material-symbols:edit-calendar-outline-rounded" class="text-lg text-[var(--primary)]" />
					{formatDateToYYYYMMDD(entry.data.updated)}
				</span>
			)}

			<!-- page views -->
			<span class="inline-flex items-center gap-1 rounded-md bg-neutral-100 px-2 py-0.5 dark:bg-neutral-800/60">
				<Icon name="material-symbols:visibility-outline-rounded" class="text-base text-[var(--primary)]" />
				<span id="page-views-count">--</span>
			</span>
			<span class="inline-flex items-center gap-1 rounded-md bg-neutral-100 px-2 py-0.5 dark:bg-neutral-800/60">
				<Icon name="material-symbols:person-outline" class="text-base text-[var(--primary)]" />
				<span id="page-visits-count">--</span>
			</span>
		</div>

		<h1 class="mb-4 text-3xl font-bold text-black/90 dark:text-white/90 md:text-[2.25rem]/[2.75rem]">
			{entry.data.title}
		</h1>

		{entry.data.description && (
			<p class="mb-6 max-w-3xl text-sm leading-relaxed text-black/70 dark:text-white/70">
				{entry.data.description}
			</p>
		)}

		<div class="mb-6 grid gap-3 md:grid-cols-2">
			<div class="rounded-xl border border-[var(--line-divider)] bg-[var(--btn-regular-bg)] p-4">
				<div class="mb-1 text-xs font-bold tracking-wide text-black/35 dark:text-white/35">项目版本</div>
				<div class="text-sm font-medium text-black/80 dark:text-white/80">{entry.data.version || "未标注"}</div>
			</div>
			<div class="rounded-xl border border-[var(--line-divider)] bg-[var(--btn-regular-bg)] p-4">
				<div class="mb-1 text-xs font-bold tracking-wide text-black/35 dark:text-white/35">项目架构</div>
				<div class="text-sm leading-relaxed text-black/80 dark:text-white/80">{entry.data.architecture || "未标注"}</div>
			</div>
		</div>

		{entry.data.video ? (
			<div class="relative mb-8 aspect-video overflow-hidden rounded-xl bg-black">
				<video
					class="work-detail-video aspect-video w-full bg-black object-contain"
					data-video-ready="false"
					src={entry.data.video}
					poster={entry.data.videoPoster || entry.data.image}
					controls
					playsinline
					preload="auto"
					referrerpolicy="origin"
				>
					当前浏览器不支持视频播放。
				</video>
				<div class="video-error-overlay absolute inset-0 flex items-center justify-center p-4" style="display: none;">
					<div class="flex items-start gap-2 rounded-xl bg-amber-50 p-3 text-xs leading-relaxed text-amber-800 dark:bg-amber-900/30 dark:text-amber-300">
						<Icon name="material-symbols:info-outline-rounded" class="mt-0.5 flex-shrink-0 text-base" />
						<span>当前视频托管于腾讯云 COS，仅支持中国网络访问。如无法播放，请更换中国网络查看。</span>
					</div>
				</div>
			</div>
		) : entry.data.image ? (
			<ImageWrapper
				id="work-cover"
				src={entry.data.image}
				alt={entry.data.title}
				basePath={path.join("content/works/", getDir(entry.id))}
				class="mb-8 rounded-xl"
				isLCP={true}
			/>
		) : null}

		{entry.data.tags.length > 0 && (
			<div class="mb-6 flex flex-wrap gap-2">
				{entry.data.tags.map((tag) => (
					<span class="rounded-md bg-[var(--btn-regular-bg)] px-2.5 py-1 text-xs font-medium text-black/45 dark:text-white/45">
						{tag}
					</span>
				))}
			</div>
		)}

		<Markdown class="mb-2 markdown-content">
			<Content />
		</Markdown>
		<MermaidRenderer />
	</article>

	<script is:inline>
		(function setupWorkVideo() {
			function bindVideo(video) {
				if (!video || video.dataset.bound === "true") return;
				video.dataset.bound = "true";
				video.addEventListener("loadedmetadata", () => {
					video.dataset.videoReady = "true";
				});
				video.addEventListener("error", () => {
					if (video.dataset.videoReady === "true") return;
					video.classList.add("hidden");
					const overlay = video.parentElement?.querySelector(".video-error-overlay");
					if (overlay) overlay.style.display = "flex";
				});
			}

			document.querySelectorAll(".work-detail-video").forEach(bindVideo);
		})();

		document.addEventListener("swup:contentReplaced", function resetWorkVideo() {
			document.querySelectorAll(".work-detail-video").forEach((video) => {
				video.dataset.bound = "";
				video.dataset.videoReady = "false";
				video.classList.remove("hidden");
				const overlay = video.parentElement?.querySelector(".video-error-overlay");
				if (overlay) overlay.style.display = "none";
			});
			setupWorkVideo();
		});
	</script>

	<script define:vars={{ slug: entry.slug, umamiConfig }}>
		// 获取作品详情页访问量统计（与文章页一致，path 指向 /works/<slug>/）
		async function fetchWorkPageViews(isRetry = false) {
			if (!umamiConfig.enable) return;
			try {
				const { websiteId, token } = await getUmamiShareData(umamiConfig.baseUrl, umamiConfig.shareId);
				const currentTimestamp = Date.now();
				const pagePath = encodeURIComponent(`eq./works/${slug}/`);
				const statsUrl = `${umamiConfig.baseUrl}/api/websites/${websiteId}/stats?startAt=0&endAt=${currentTimestamp}&unit=hour&timezone=${encodeURIComponent(umamiConfig.timezone)}&path=${pagePath}`;

				const statsResponse = await fetch(statsUrl, {
					headers: {
						'x-umami-share-token': token,
						'x-umami-share-context': 'true',
					},
				});

				if (!statsResponse.ok) {
					if (statsResponse.status === 401 && !isRetry) {
						clearUmamiShareCache();
						return fetchWorkPageViews(true);
					}
					throw new Error('获取统计数据失败');
				}

				const statsData = await statsResponse.json();
				const pageViewsElement = document.getElementById('page-views-count');
				const visitsElement = document.getElementById('page-visits-count');
				if (pageViewsElement) pageViewsElement.textContent = (statsData.pageviews || 0).toString();
				if (visitsElement) visitsElement.textContent = (statsData.visits || 0).toString();
			} catch (error) {
				console.error('Error fetching work page views:', error);
				const pageViewsElement = document.getElementById('page-views-count');
				const visitsElement = document.getElementById('page-visits-count');
				if (pageViewsElement) pageViewsElement.textContent = '-';
				if (visitsElement) visitsElement.textContent = '-';
			}
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', fetchWorkPageViews);
		} else {
			fetchWorkPageViews();
		}
		document.addEventListener('swup:contentReplaced', fetchWorkPageViews);
	</script>
</MainGridLayout>
