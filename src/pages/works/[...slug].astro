---
import path from "node:path";
import { Icon } from "astro-icon/components";
import type { CollectionEntry } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedWorks } from "@utils/content-utils";
import { getDir } from "@utils/url-utils";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { profileConfig, siteConfig } from "@/config";

export async function getStaticPaths() {
	const works = await getSortedWorks();
	return works.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props as { entry: CollectionEntry<"works"> };
const { Content, headings } = await entry.render();

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CreativeWork",
	name: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
	...(entry.data.image && { image: new URL(entry.data.image, Astro.site).href }),
	...(entry.data.video && { video: entry.data.video }),
};
---

<MainGridLayout
	banner={entry.data.image}
	title={entry.data.title}
	description={entry.data.description}
	lang={entry.data.lang}
	setOGTypeArticle={true}
	headings={headings}
>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

	<article class="card-base relative z-10 overflow-hidden rounded-[var(--radius-large)] px-6 pb-6 pt-6 md:px-9">
		<div class="mb-5 flex flex-wrap items-center gap-3 text-sm text-black/45 dark:text-white/45">
			<span class="inline-flex items-center gap-2">
				<Icon name="material-symbols:calendar-today-outline-rounded" class="text-lg text-[var(--primary)]" />
				{formatDateToYYYYMMDD(entry.data.published)}
			</span>
			{entry.data.updated && entry.data.updated.getTime() !== entry.data.published.getTime() && (
				<span class="inline-flex items-center gap-2">
					<Icon name="material-symbols:edit-calendar-outline-rounded" class="text-lg text-[var(--primary)]" />
					{formatDateToYYYYMMDD(entry.data.updated)}
				</span>
			)}
		</div>

		<h1 class="mb-4 text-3xl font-bold text-black/90 dark:text-white/90 md:text-[2.25rem]/[2.75rem]">
			{entry.data.title}
		</h1>

		{entry.data.description && (
			<p class="mb-6 max-w-3xl text-sm leading-relaxed text-black/70 dark:text-white/70">
				{entry.data.description}
			</p>
		)}

		<div class="mb-6 grid gap-3 md:grid-cols-2">
			<div class="rounded-xl border border-[var(--line-divider)] bg-[var(--btn-regular-bg)] p-4">
				<div class="mb-1 text-xs font-bold tracking-wide text-black/35 dark:text-white/35">项目版本</div>
				<div class="text-sm font-medium text-black/80 dark:text-white/80">{entry.data.version || "未标注"}</div>
			</div>
			<div class="rounded-xl border border-[var(--line-divider)] bg-[var(--btn-regular-bg)] p-4">
				<div class="mb-1 text-xs font-bold tracking-wide text-black/35 dark:text-white/35">项目架构</div>
				<div class="text-sm leading-relaxed text-black/80 dark:text-white/80">{entry.data.architecture || "未标注"}</div>
			</div>
		</div>

		{entry.data.video ? (
			<div class="mb-8 overflow-hidden rounded-xl bg-black">
				<video
					class="aspect-video w-full bg-black object-contain"
					src={entry.data.video}
					poster={entry.data.videoPoster || entry.data.image}
					controls
					playsinline
					preload="metadata"
				>
					当前浏览器不支持视频播放。
				</video>
			</div>
		) : entry.data.image ? (
			<ImageWrapper
				id="work-cover"
				src={entry.data.image}
				alt={entry.data.title}
				basePath={path.join("content/works/", getDir(entry.id))}
				class="mb-8 rounded-xl"
				isLCP={true}
			/>
		) : null}

		{entry.data.tags.length > 0 && (
			<div class="mb-6 flex flex-wrap gap-2">
				{entry.data.tags.map((tag) => (
					<span class="rounded-md bg-[var(--btn-regular-bg)] px-2.5 py-1 text-xs font-medium text-black/45 dark:text-white/45">
						{tag}
					</span>
				))}
			</div>
		)}

		<Markdown class="mb-2 markdown-content">
			<Content />
		</Markdown>
	</article>
</MainGridLayout>
